{
  "name": "@mcp-hub/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "migrate": "tsx src/migrate.ts",
    "migrate:dry-run": "tsx src/migrate.ts --dry-run",
    "seed": "tsx src/seed.ts",
    "seed:dry-run": "tsx src/seed.ts --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run src/validation.test.ts",
    "test:integration": "vitest run src/repositories.test.ts"
  },
  "dependencies": {
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  }
}
