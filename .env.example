NODE_ENV=development
APP_ENV=development
DATABASE_URL=postgres://mcp:mcp@localhost:5432/mcp_hub
REDIS_URL=redis://localhost:6379
OIDC_ISSUER_URL=http://localhost:8080/realms/mcp-hub
OIDC_AUDIENCE=mcp-hub
OIDC_REQUIRED_SCOPE=mcp:gateway
OIDC_JWKS_URL=http://localhost:8080/realms/mcp-hub/protocol/openid-connect/certs
# OIDC_HS256_SECRET is for local tests only; shared deployments should use RS256/JWKS.
OIDC_HS256_SECRET=
OIDC_CLIENT_ID=mcp-hub-web
OIDC_CLIENT_SECRET=dev-secret
MCP_AUTH_MODE=mock
MCP_ALLOW_MOCK_TOKENS=false
MCP_TRUSTED_AUTH_HEADERS=false
MCP_ALLOW_DYNAMIC_CLIENTS=false
MCP_STORE_PATH=/tmp/mcp-hub/store.json
MCP_PROJECT_ID=00000000-0000-4000-8000-000000000020
MCP_HUB_PUBLIC_URL=http://localhost:3000
MCP_API_URL=http://localhost:4000
MCP_GATEWAY_URL=http://localhost:5000
MCP_WEB_AUTH_ENABLED_PROVIDERS=dev
MCP_WEB_SESSION_SECRET=dev-only-change-me
MCP_WEB_SESSION_COOKIE_NAME=mcp_hub_session
MCP_WEB_SESSION_TTL_SECONDS=28800
MCP_WEB_LOCAL_AUTH_ENABLED=false
MCP_WEB_LOCAL_USERS=
MCP_WEB_DEV_AUTH_ENABLED=true
# Example OIDC provider config. Add "okta" to MCP_WEB_AUTH_ENABLED_PROVIDERS to expose it.
MCP_WEB_OIDC_OKTA_ENABLED=false
MCP_WEB_OIDC_OKTA_DISPLAY_NAME=Okta
MCP_WEB_OIDC_OKTA_ISSUER_URL=https://example.okta.com/oauth2/default
MCP_WEB_OIDC_OKTA_CLIENT_ID=example-client-id
MCP_WEB_OIDC_OKTA_CLIENT_SECRET=
MCP_WEB_OIDC_OKTA_SCOPES=openid profile email groups
MCP_WEB_OIDC_OKTA_ADMIN_GROUPS=platform-admins,mcp-hub-admins
MCP_GATEWAY_RATE_LIMIT=1000
MCP_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
MCP_GATEWAY_SESSION_IDLE_SECONDS=300
MCP_GATEWAY_UPSTREAM_TIMEOUT_SECONDS=2
MCP_GATEWAY_CIRCUIT_THRESHOLD=3
MCP_GATEWAY_CIRCUIT_OPEN_SECONDS=30
LOG_LEVEL=debug
API_PORT=4000
GATEWAY_PORT=5000
WORKER_PORT=4100
K8S_MCP_PORT=5102
# Corporate network development/build placeholders. Runtime Helm workloads do not set HTTP proxy by default.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.svc,.cluster.local
# Optional local path to a PEM .crt file that can be copied into deploy/certs/ before image builds.
MCP_CORPORATE_CA_CERT_PATH=
