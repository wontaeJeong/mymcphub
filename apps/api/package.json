  },
  "dependencies": {
    "@mcp-hub/auth": "workspace:*",
    "@mcp-hub/db": "workspace:*",
    "@mcp-hub/logger": "workspace:*",
    "fastify": "^5.4.0",
    "prom-client": "^15.1.3"
  }
}
