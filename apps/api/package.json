{
  "name": "@mcp-hub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "openapi:write": "tsx src/write-openapi.ts",
    "test": "vitest run --passWithNoTests",
