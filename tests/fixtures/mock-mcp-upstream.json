{
  "serverInfo": {
    "name": "fixture-upstream",
    "version": "0.1.0"
  },
  "tools": [
    {
      "name": "fixture_echo",
      "description": "Echo fixture arguments back as MCP text content.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"],
        "additionalProperties": false
      }
    }
  ],
  "responses": {
    "initialize": {
      "protocolVersion": "2025-03-26",
      "capabilities": { "tools": {} }
    },
    "tools/call": {
      "content": [{ "type": "text", "text": "fixture-ok" }]
    }
  }
}
