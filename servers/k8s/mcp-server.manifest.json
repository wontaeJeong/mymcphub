{
  "slug": "k8s-readonly",
  "displayName": "Kubernetes Readonly MCP Server",
  "description": "First-party medium-risk read-only Kubernetes MCP server implemented in Go with local mock data by default.",
  "environment": "dev",
  "transport": "streamable_http",
  "upstreamUrl": "http://localhost:5102/mcp",
  "riskLevel": "medium",
  "version": "v1",
  "ownerTeam": "Platform Team",
  "ownerTeamId": "00000000-0000-4000-8000-000000000010",
  "implementationLanguage": "go",
  "policyTags": ["kubernetes", "readonly", "namespace-scope"],
  "runtime": {
    "image": "registry.example.com/mcp-hub/k8s:latest",
    "imagePullPolicy": "IfNotPresent",
    "port": 5102,
    "replicas": 1,
    "path": "/mcp"
  },
  "egress": {
    "denyByDefault": true,
    "allow": []
  },
  "sandbox": {
    "profile": "restricted",
    "runAsNonRoot": true,
    "runAsUser": 10001,
    "readOnlyRootFilesystem": true,
    "allowPrivilegeEscalation": false,
    "seccompProfileType": "RuntimeDefault",
    "resources": {
      "requests": { "cpu": "25m", "memory": "64Mi" },
      "limits": { "cpu": "250m", "memory": "256Mi" }
    }
  },
  "tools": [
    {
      "name": "list_namespaces",
      "description": "List namespace names from the local read-only mock Kubernetes dataset.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["kubernetes", "readonly", "namespace-scope"],
      "inputSchema": { "type": "object", "properties": {}, "additionalProperties": false }
    },
    {
      "name": "list_pods",
      "description": "List pods in one namespace from the local read-only mock Kubernetes dataset.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["kubernetes", "readonly", "pods"],
      "inputSchema": {
        "type": "object",
        "properties": { "namespace": { "type": "string", "description": "Namespace to inspect." } },
        "required": ["namespace"],
        "additionalProperties": false
      }
    },
    {
      "name": "get_pod",
      "description": "Read one pod by namespace and name from the local read-only mock Kubernetes dataset.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["kubernetes", "readonly", "pods"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "namespace": { "type": "string", "description": "Pod namespace." },
          "podName": { "type": "string", "description": "Pod name." }
        },
        "required": ["namespace", "podName"],
        "additionalProperties": false
      }
    }
  ]
}
