{
  "version": "v1",
  "slug": "gitlab-readonly",
  "displayName": "GitLab Readonly MCP Server",
  "description": "First-party Go GitLab provider MCP server with read-only project and merge request metadata tools.",
  "environment": "dev",
  "transport": "streamable_http",
  "upstreamUrl": "http://localhost:5112/mcp",
  "riskLevel": "medium",
  "ownerTeam": "Platform Team",
  "ownerTeamId": "00000000-0000-4000-8000-000000000010",
  "implementationLanguage": "go",
  "policyTags": ["git-provider", "gitlab", "readonly"],
  "runtime": {
    "image": "registry.example.com/mcp-hub/gitlab:latest",
    "imagePullPolicy": "IfNotPresent",
    "port": 5112,
    "replicas": 1,
    "path": "/mcp"
  },
  "secrets": [
    {
      "ref": "gitlab-provider-token",
      "targetEnv": "GITLAB_TOKEN",
      "secretName": "gitlab-provider",
      "secretKey": "token",
      "leaseDurationSeconds": 1800
    }
  ],
  "egress": {
    "denyByDefault": true,
    "allow": [{ "host": "gitlab.com", "port": 443, "protocol": "TCP" }]
  },
  "sandbox": {
    "profile": "restricted",
    "runAsNonRoot": true,
    "runAsUser": 10001,
    "readOnlyRootFilesystem": true,
    "allowPrivilegeEscalation": false,
    "seccompProfileType": "RuntimeDefault",
    "resources": {
      "requests": { "cpu": "50m", "memory": "64Mi" },
      "limits": { "cpu": "500m", "memory": "256Mi" }
    }
  },
  "tools": [
    {
      "name": "list_projects",
      "description": "List approved GitLab projects visible to the bound provider token.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["git-provider", "gitlab", "readonly"],
      "inputSchema": { "type": "object", "properties": {}, "additionalProperties": false }
    },
    {
      "name": "get_merge_request",
      "description": "Read merge request summary metadata for an approved GitLab project.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["git-provider", "gitlab", "readonly", "merge-requests"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "project": { "type": "string" },
          "iid": { "type": "integer" }
        },
        "required": ["project", "iid"],
        "additionalProperties": false
      }
    }
  ]
}
