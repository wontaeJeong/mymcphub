{
  "version": "v1",
  "slug": "github-readonly",
  "displayName": "GitHub Readonly MCP Server",
  "description": "First-party Go GitHub provider MCP server with read-only repository, pull request, and issue metadata tools.",
  "environment": "dev",
  "transport": "streamable_http",
  "upstreamUrl": "http://localhost:5111/mcp",
  "riskLevel": "medium",
  "ownerTeam": "Platform Team",
  "ownerTeamId": "00000000-0000-4000-8000-000000000010",
  "implementationLanguage": "go",
  "policyTags": ["git-provider", "github", "readonly"],
  "runtime": {
    "image": "registry.example.com/mcp-hub/github:latest",
    "imagePullPolicy": "IfNotPresent",
    "port": 5111,
    "replicas": 1,
    "path": "/mcp"
  },
  "secrets": [
    {
      "ref": "github-provider-token",
      "targetEnv": "GITHUB_TOKEN",
      "secretName": "github-provider",
      "secretKey": "token",
      "leaseDurationSeconds": 1800
    }
  ],
  "egress": {
    "denyByDefault": true,
    "allow": [{ "host": "api.github.com", "port": 443, "protocol": "TCP" }]
  },
  "sandbox": {
    "profile": "restricted",
    "runAsNonRoot": true,
    "runAsUser": 10001,
    "readOnlyRootFilesystem": true,
    "allowPrivilegeEscalation": false,
    "seccompProfileType": "RuntimeDefault",
    "resources": {
      "requests": { "cpu": "50m", "memory": "64Mi" },
      "limits": { "cpu": "500m", "memory": "256Mi" }
    }
  },
  "tools": [
    {
      "name": "list_repositories",
      "description": "List approved GitHub repositories visible to the bound provider token.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["git-provider", "github", "readonly"],
      "inputSchema": { "type": "object", "properties": {}, "additionalProperties": false }
    },
    {
      "name": "get_pull_request",
      "description": "Read pull request summary metadata for an approved GitHub repository.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["git-provider", "github", "readonly", "pull-requests"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "repository": { "type": "string" },
          "number": { "type": "integer" }
        },
        "required": ["repository", "number"],
        "additionalProperties": false
      }
    },
    {
      "name": "search_issues",
      "description": "Search issue titles in approved GitHub repositories without returning secret-bearing fields.",
      "riskLevel": "medium",
      "readOnly": true,
      "policyTags": ["git-provider", "github", "readonly", "issues"],
      "inputSchema": {
        "type": "object",
        "properties": { "query": { "type": "string" } },
        "required": ["query"],
        "additionalProperties": false
      }
    }
  ]
}
