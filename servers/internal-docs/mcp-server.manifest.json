{
  "slug": "internal-docs",
  "displayName": "Internal Docs MCP Server",
  "description": "First-party read-only MCP server backed by committed synthetic internal documentation.",
  "environment": "dev",
  "transport": "streamable_http",
  "upstreamUrl": "http://localhost:5101/mcp",
  "riskLevel": "medium",
  "ownerTeam": "Platform Team",
  "ownerTeamId": "00000000-0000-4000-8000-000000000010",
  "tools": [
    {
      "name": "search_docs",
      "description": "Search synthetic internal documentation by keyword and return deterministic snippets.",
      "riskLevel": "low",
      "readOnly": true,
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query." },
          "limit": { "type": "number", "minimum": 1, "maximum": 10, "description": "Maximum number of results." }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    },
    {
      "name": "read_doc",
      "description": "Read one synthetic internal document by id.",
      "riskLevel": "low",
      "readOnly": true,
      "inputSchema": {
        "type": "object",
        "properties": {
          "docId": { "type": "string", "description": "Document id returned by search_docs." }
        },
        "required": ["docId"],
        "additionalProperties": false
      }
    }
  ]
}
