{
  "name": "mcp-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev --filter=@mcp-hub/web --filter=@mcp-hub/api --filter=@mcp-hub/gateway --filter=@mcp-hub/worker --filter=@mcp-hub/server-echo --filter=@mcp-hub/server-internal-docs --filter=@mcp-hub/server-k8s-readonly",
    "dev:stdio-adapter": "pnpm --filter @mcp-hub/server-stdio-sample build && STDIO_MCP_COMMAND=node STDIO_MCP_ARGS=servers/stdio-sample/dist/index.js STDIO_WORKDIR=../.. PORT=5103 pnpm --filter @mcp-hub/stdio-adapter dev",
    "dev:infra": "scripts/dev/up-infra.sh",
    "dev:infra:down": "scripts/dev/down-infra.sh",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgres://mcp:mcp@localhost:5432/mcp_hub} pnpm --filter @mcp-hub/db migrate",
    "db:seed": "scripts/dev/seed.sh",
    "dev:reset-db": "scripts/dev/reset-db.sh",
    "dev:seed": "scripts/dev/seed.sh",
    "dev:smoke-test": "scripts/dev/smoke-test.sh",
    "dev:create-mock-token": "scripts/dev/create-mock-token.sh",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "security:deps": "scripts/security/scan-deps.sh",
    "security:images": "scripts/security/scan-images.sh",
    "security:secrets": "scripts/security/scan-secrets.sh",
    "security:k8s": "scripts/security/scan-k8s-manifests.sh",
    "security:mcp-manifests": "tsx scripts/security/check-mcp-manifest.ts",
    "security:check": "scripts/security/check-all.sh",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm security:smoke && pnpm helm:template",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "helm:template": "bash tests/helm-template.sh",
    "security:smoke": "pnpm security:mcp-manifests"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
