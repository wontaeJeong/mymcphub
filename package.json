{
  "name": "mcp-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "make dev",
    "dev:infra": "scripts/dev/up-infra.sh",
    "dev:infra:down": "scripts/dev/down-infra.sh",
    "db:migrate": "scripts/dev/db-migrate.sh",
    "db:seed": "scripts/dev/seed.sh",
    "dev:reset-db": "scripts/dev/reset-db.sh",
    "dev:seed": "scripts/dev/seed.sh",
    "dev:smoke-test": "scripts/dev/smoke-test.sh",
    "dev:create-mock-token": "scripts/dev/create-mock-token.sh",
    "build": "make build",
    "lint": "make lint",
    "test": "make test",
    "typecheck": "pnpm --filter @mcp-hub/ui typecheck && pnpm --filter @mcp-hub/web typecheck",
    "format": "prettier --write .",
    "security:deps": "scripts/security/scan-deps.sh",
    "security:supply-chain": "scripts/security/scan-supply-chain.sh",
    "security:images": "scripts/security/scan-images.sh",
    "security:sbom": "scripts/security/sbom-sign-images.sh",
    "security:secrets": "scripts/security/scan-secrets.sh",
    "security:k8s": "scripts/security/scan-k8s-manifests.sh",
    "security:mcp-manifests": "go run ./scripts/security/check-mcp-manifest.go",
    "security:check": "scripts/security/check-all.sh",
    "ci": "make ci",
    "docs:sync": "uv sync --group docs",
    "docs:serve": "uv run --group docs mkdocs serve",
    "docs:build": "uv run --group docs mkdocs build --strict",
    "docs:check": "uv run --group docs mkdocs build --strict",
    "test:unit": "go test ./internal/... && pnpm --filter @mcp-hub/ui test && pnpm --filter @mcp-hub/web test:unit",
    "test:integration": "go test ./apps/... ./tests/...",
    "test:e2e": "go test ./tests/e2e ./tests/security",
    "helm:template": "bash tests/helm-template.sh",
    "security:smoke": "pnpm security:mcp-manifests",
    "release:notes": "bash scripts/release/generate-notes.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
