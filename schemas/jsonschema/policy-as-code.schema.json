{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Hub Policy-As-Code Document",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["effect", "reasonCode"],
        "properties": {
          "effect": { "enum": ["allow", "deny", "needs_approval"] },
          "reasonCode": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" },
          "requiresApproval": { "type": "boolean" },
          "serverIds": { "type": "array", "items": { "type": "string" } },
          "serverSlugs": { "type": "array", "items": { "type": "string" } },
          "toolNames": { "type": "array", "items": { "type": "string" } },
          "subjectIds": { "type": "array", "items": { "type": "string" } },
          "clientIds": { "type": "array", "items": { "type": "string" } },
          "environments": { "type": "array", "items": { "enum": ["dev", "stg", "prod", "shared"] } },
          "riskLevels": { "type": "array", "items": { "enum": ["low", "medium", "high", "critical"] } }
        },
        "additionalProperties": false,
        "anyOf": [
          { "required": ["serverIds"] },
          { "required": ["serverSlugs"] },
          { "required": ["toolNames"] },
          { "required": ["subjectIds"] },
          { "required": ["clientIds"] },
          { "required": ["environments"] },
          { "required": ["riskLevels"] }
        ]
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "serverId": { "type": "string" },
        "serverSlug": { "type": "string" },
        "toolName": { "type": "string" },
        "subjectId": { "type": "string" },
        "clientId": { "type": "string" },
        "environment": { "enum": ["dev", "stg", "prod", "shared"] },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
