{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Hub Grant Request",
  "type": "object",
  "required": ["subjectType", "subjectId", "projectId", "serverId", "allowedTools", "environment", "reason"],
  "properties": {
    "subjectType": { "enum": ["user", "team", "service_account"] },
    "subjectId": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "serverId": { "type": "string", "minLength": 1 },
    "allowedTools": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "environment": { "enum": ["dev", "stg", "prod", "shared"] },
    "expiresAt": { "type": "string", "format": "date-time" },
    "approvedBy": { "type": "string" },
    "reason": { "type": "string", "minLength": 1 },
    "ticketUrl": { "type": "string", "format": "uri" },
    "enabled": { "type": "boolean", "default": true }
  }
}
