{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Hub Audit Event",
  "type": "object",
  "required": ["id", "timestamp", "eventType", "riskLevel", "policyDecision", "traceId", "metadataJson"],
  "properties": {
    "id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "userId": { "type": "string" },
    "teamId": { "type": "string" },
    "projectId": { "type": "string" },
    "clientId": { "type": "string" },
    "sessionId": { "type": "string" },
    "serverId": { "type": "string" },
    "toolName": { "type": "string" },
    "eventType": { "type": "string" },
    "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
    "policyDecision": { "enum": ["allow", "deny", "needs_approval"] },
    "traceId": { "type": "string" },
    "argumentHash": { "type": "string" },
    "argumentRedactedJson": {},
    "latencyMs": { "type": "integer", "minimum": 0 },
    "upstreamStatus": { "type": "integer" },
    "errorCode": { "type": "string" },
    "metadataJson": { "type": "object" }
  }
}
