{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Hub Client Profile",
  "type": "object",
  "required": ["client", "profile"],
  "properties": {
    "client": { "enum": ["generic", "opencode", "claude-code", "codex", "vscode"] },
    "profile": { "type": "string", "minLength": 1 },
    "serverId": { "type": "string" },
    "serverSlug": { "type": "string" },
    "gatewayUrl": { "type": "string", "format": "uri" },
    "auth": {
      "type": "object",
      "properties": {
        "type": { "const": "bearer" },
        "header": { "const": "authorization" },
        "tokenEnv": { "type": "string" },
        "requiredScope": { "type": "string" }
      }
    },
    "config": { "type": "object" },
    "placeholder": { "type": "boolean" }
  }
}
