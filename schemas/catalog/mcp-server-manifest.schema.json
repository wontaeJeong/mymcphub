{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Server Manifest",
  "type": "object",
  "required": ["slug", "displayName", "ownerTeamId", "environment", "transport", "riskLevel", "implementationLanguage", "tools"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "ownerTeam": { "type": "string" },
    "ownerTeamId": { "type": "string", "format": "uuid" },
    "environment": { "enum": ["dev", "stg", "prod", "shared"] },
    "transport": { "enum": ["streamable_http", "sse_legacy", "stdio_adapter", "external"] },
    "upstreamUrl": { "type": "string", "format": "uri" },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "enabled": { "type": "boolean", "default": true },
    "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
    "implementationLanguage": { "enum": ["go", "python", "typescript"] },
    "version": { "type": "string" },
    "policyTags": { "type": "array", "items": { "type": "string" } },
    "runtime": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "imagePullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] },
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "replicas": { "type": "integer", "minimum": 0 },
        "serviceAccountName": { "type": "string" },
        "path": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "targetEnv", "secretName", "secretKey"],
        "properties": {
          "ref": { "type": "string" },
          "targetEnv": { "type": "string" },
          "secretName": { "type": "string" },
          "secretKey": { "type": "string" },
          "leaseDurationSeconds": { "type": "integer", "minimum": 60 }
        },
        "not": { "anyOf": [{ "required": ["value"] }, { "required": ["token"] }, { "required": ["credential"] }, { "required": ["password"] }, { "required": ["clientSecret"] }] },
        "additionalProperties": false
      }
    },
    "egress": {
      "type": "object",
      "properties": {
        "denyByDefault": { "type": "boolean" },
        "allow": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "cidr": { "type": "string" },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "enum": ["TCP", "UDP"] }
            },
            "anyOf": [{ "required": ["host"] }, { "required": ["cidr"] }],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "profile": { "enum": ["restricted", "gvisor", "kata"] },
        "runtimeClassName": { "type": "string" },
        "seccompProfileType": { "enum": ["RuntimeDefault", "Localhost"] },
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 1 },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "allowPrivilegeEscalation": { "type": "boolean" },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object", "additionalProperties": { "type": "string" } },
            "limits": { "type": "object", "additionalProperties": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "riskLevel", "inputSchema"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "enabled": { "type": "boolean", "default": true },
          "readOnly": { "type": "boolean" },
          "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
          "policyTags": { "type": "array", "items": { "type": "string" } },
          "inputSchema": {
            "type": "object",
            "required": ["type", "additionalProperties"],
            "properties": {
              "type": { "const": "object" },
              "additionalProperties": { "const": false }
            },
            "additionalProperties": true
          },
          "outputSchema": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
